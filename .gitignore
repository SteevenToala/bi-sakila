paso_2_dataset/dataset_base.csv
paso_2_dataset/dataset_neuronal.csv

# -----------------------------------------------------------------------------
# Imágenes generadas por el EDA (se regeneran con analisis_exploratorio.py)
# -----------------------------------------------------------------------------
